# ============================================================
#  AVENGERS · Factoría de Software Autónoma
#  Plantilla de variables de entorno — NO subir .env real
# ============================================================

# ── LLM Providers ────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Social / Data Sources ────────────────────────────────────
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=mongodb://localhost:27017/avengers
# Alternativa SQL:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/avengers

# ── App Config ───────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
MAX_CONTEXT_LINES=300
